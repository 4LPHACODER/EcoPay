{
  "version": 2,
  "framework": null,

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },

  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],

  "build": {
    "env": {
      "PHP_VERSION": "8.2"
    }
  },

  "outputDirectory": "public",
  "installCommand": "composer install --optimize-autoloader --no-dev",
  "buildCommand": "php artisan route:cache && php artisan config:cache && php artisan view:cache"
}
